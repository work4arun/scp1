# Copy this file to `.env` next to docker-compose.yml and fill in real values.
# Anything in this file is visible only to the two containers; nothing leaks to the host.

# === Postgres (container only — not the host's Postgres) ===
POSTGRES_DB=scp
POSTGRES_USER=scp
# Use a strong random value: openssl rand -base64 24
POSTGRES_PASSWORD=change-me-please

# === App ===
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-please-generate-a-real-secret

# Public URL the user types in the browser.
# Since you are deploying directly via IP, put your AWS Public IP here (e.g. http://1.2.3.4)
NEXTAUTH_URL=http://<YOUR_AWS_PUBLIC_IP>

# Set to 1 the FIRST time you bring the stack up to seed reference data + demo users.
# After the first successful boot, set back to 0 (or remove) to avoid re-seeding on every restart.
SCP_SEED=0

# === Email (SMTP) ===
# If SMTP_HOST is left empty, task notification emails are silently skipped — no crash.
# Gmail example: use an App Password (https://myaccount.google.com/apppasswords)
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false        ← "true" only for port 465
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx    ← 16-char Gmail App Password
#   SMTP_FROM=StartOS <youraddress@gmail.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Full public URL where your app is hosted — used to build task links inside emails.
# Must match NEXTAUTH_URL.  e.g. http://65.0.0.1  or  https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://<YOUR_AWS_PUBLIC_IP>
