# Copy this file to `.env` next to docker-compose.yml and fill in real values.
# Anything in this file is visible only to the two containers; nothing leaks to the host.

# === Postgres (container only — not the host's Postgres) ===
POSTGRES_DB=scp
POSTGRES_USER=scp
# Use a strong random value: openssl rand -base64 24
POSTGRES_PASSWORD=change-me-please

# === App ===
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-please-generate-a-real-secret

# Public URL the user types in the browser.
# Since you are deploying directly via IP, put your AWS Public IP here (e.g. http://1.2.3.4)
NEXTAUTH_URL=http://<YOUR_AWS_PUBLIC_IP>

# Set to 1 the FIRST time you bring the stack up to seed reference data + demo users.
# After the first successful boot, set back to 0 (or remove) to avoid re-seeding on every restart.
SCP_SEED=0
