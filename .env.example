# ─────────────────────────────────────────────────────────────────────────────
#  Strategic Control Portal — environment variables template
#  Copy to .env and fill in real values before running setup.sh or npm run dev.
#  NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local development default (assumes Postgres on localhost with your system user)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/startos?schema=public"

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
# setup.sh auto-fills this placeholder — do not change the placeholder text.
AUTH_SECRET="replace-with-a-long-random-string"
# NextAuth v5 also reads NEXTAUTH_SECRET as a fallback — set it to the same value.
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# The full public URL where the app is served.
# Local dev:       http://localhost:3000
# VPS sub-path:    https://rathinamtechnicalcampus.com/scp
NEXTAUTH_URL="http://localhost:3000"

# ── Sub-path deployment ───────────────────────────────────────────────────────
# Set to "/scp" when the app is served from https://domain.com/scp via Nginx.
# Leave empty (or remove) when serving from the root domain.
BASE_PATH=""

# ── Public URL (used in email links) ─────────────────────────────────────────
# Same value as NEXTAUTH_URL — copied here for use in client-side code.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Email (optional — emails are silently skipped if SMTP_HOST is not set) ───
# Example for Gmail:  SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com
SMTP_HOST=""
SMTP_PORT="587"
# Set to "true" only for port 465 (SSL). Leave empty or "false" for STARTTLS (port 587).
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
# Display name + address shown in the From header.  e.g. "StartOS <noreply@example.com>"
SMTP_FROM=""

# ── Seed credentials override (optional) ─────────────────────────────────────
# These control the default passwords created by `npm run db:seed`.
# Leave unset to use the built-in defaults shown in prisma/seed.ts.
# SEED_SUPERADMIN_EMAIL=sadmin@rathinam.in
# SEED_SUPERADMIN_PASSWORD=SuperAdmin@123
# SEED_CBO_EMAIL=cbo@rathinam.in
# SEED_CBO_PASSWORD=Cbo@123
# SEED_SM_EMAIL=sm@rathinam.in
# SEED_SM_PASSWORD=Sm@123
