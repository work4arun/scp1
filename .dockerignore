# ─────────────────────────────────────────────────────────────────────────────
#  .dockerignore — what Docker should NEVER copy into the build context
# ─────────────────────────────────────────────────────────────────────────────
#  Without this file the build context can balloon by ~1 GB+:
#    node_modules (~800 MB), .next (~230 MB), .git (~80 MB), tsbuildinfo (~115 KB)
#  That bloats the layer cache and can cause `ENOSPC: no space left on device`
#  on disk-constrained hosts. Keep this file in sync with the one in scp-deploy/.
# ─────────────────────────────────────────────────────────────────────────────

# Dependencies — installed fresh inside the image
node_modules
**/node_modules

# Build artifacts — regenerated by `next build`
.next
out
dist
build
coverage

# TypeScript incremental cache — useless inside the container
tsconfig.tsbuildinfo
*.tsbuildinfo

# Version control
.git
.gitignore
.gitattributes

# Local env files — secrets must come from compose / runtime env, NOT the image
.env
.env.*
!.env.example

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
logs

# OS / editor cruft
.DS_Store
.vscode
.idea
*.swp
*.swo
Thumbs.db

# Docs — not needed at runtime
README.md
DEPLOYMENT.md
DEPLOYMENT_GUIDE.md
DIAGNOSIS_REPORT.md
*.md
!prisma/**/*.md

# Tests and CI metadata (none today, but future-proofing)
.github
.circleci
.gitlab-ci.yml
test
tests
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx

# Deploy directory — Dockerfile / compose / entrypoint are copied in separately
scp-deploy

# Misc
.npm
.cache
.parcel-cache
.turbo
.vercel
tmp
temp

# Don't include the dockerignore or the Dockerfile itself in the image layers
.dockerignore
Dockerfile
docker-compose.yml
